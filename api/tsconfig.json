{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noEmit": false,
    "isolatedModules": true,
    "allowJs": true,
    "jsx": "preserve",
    "lib": ["ES2020", "DOM"],
    "baseUrl": "..",
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["./**/*.ts", "../server/**/*.ts", "../shared/**/*.ts"],
  "exclude": ["../node_modules", "../client", "../dist"]
}
