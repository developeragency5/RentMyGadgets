{
  "version": 2,
  "buildCommand": "npx vite build",
  "outputDirectory": "dist/public",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "excludeFiles": "{node_modules/puppeteer/**,node_modules/puppeteer-core/**,node_modules/@puppeteer/**,node_modules/chromium-bidi/**,node_modules/electron-to-chromium/**,node_modules/playwright*/**,node_modules/@swc/**,node_modules/typescript/**,node_modules/@types/**,node_modules/esbuild/**,node_modules/@esbuild/**,node_modules/vite/**,node_modules/@vitejs/**,node_modules/tsx/**,node_modules/drizzle-kit/**,attached_assets/**,public/images/**,client/public/images/**,client/src/**,**/*.test.ts,**/*.spec.ts,**/*.md}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/sitemap.xml", "destination": "/api/index" },
    { "source": "/robots.txt", "destination": "/api/index" },
    { "source": "/((?!.*\\.).*)", "destination": "/api/index" }
  ]
}
